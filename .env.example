# Supabase connection string.
# Local dev:  copy from `supabase status` after running `supabase start`
# Production: copy from Supabase dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Protect admin routes. Use any strong password.
# Generate one with: openssl rand -hex 32
ADMIN_SECRET=replace-me-with-a-strong-secret
