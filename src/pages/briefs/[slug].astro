---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { sql } from "../../lib/db.mjs";

const { slug } = Astro.params;

const [briefRows] = await Promise.all([
  sql`
    SELECT l.*, c.name AS category_name, c.slug AS category_slug, c.label AS category_label
    FROM links l JOIN categories c ON l.category_id = c.id
    WHERE l.slug = ${slug} AND l.status = 'published'
  `,
]);

const brief = briefRows[0];
if (!brief) return Astro.redirect("/", 302);

// Fetch candidates for related posts, score in JS using metadata overlap
const candidates = await sql`
  SELECT l.id, l.title, l.slug, l.reader_hook, l.impact_badge,
         l.read_next_tags, l.job_relevance, l.audience, l.category_id,
         c.label AS category_label, c.slug AS category_slug
  FROM links l JOIN categories c ON l.category_id = c.id
  WHERE l.status = 'published' AND l.id != ${brief.id}
  ORDER BY l.published_at DESC
  LIMIT 40
`;

function arrOverlap(a: string[] | null, b: string[] | null): number {
  if (!a?.length || !b?.length) return 0;
  return a.filter(x => b!.includes(x)).length;
}

const related = [...candidates]
  .map((r: any) => ({
    ...r,
    _score:
      arrOverlap(r.read_next_tags, brief.read_next_tags) * 4 +
      arrOverlap(r.job_relevance,  brief.job_relevance)  * 2 +
      arrOverlap(r.audience,       brief.audience)       * 1 +
      (r.category_id === brief.category_id ? 1 : 0),
  }))
  .sort((a: any, b: any) => b._score - a._score)
  .slice(0, 4);

// Related angle sentence from job_relevance + business_impact
function buildRelatedAngle(jobRel: string[] | null, bizImp: string[] | null): string {
  const parts: string[] = [];
  if (jobRel?.length) parts.push(jobRel.slice(0, 3).join(", ").toLowerCase());
  if (bizImp?.length) parts.push(bizImp.slice(0, 2).join(", ").toLowerCase());
  if (!parts.length) return "";
  return `This connects to ${parts.join(", and ")}.`;
}

const relatedAngle = buildRelatedAngle(brief.job_relevance, brief.business_impact);
const showWtfModule = brief.weirdness_level === "Odd" || brief.weirdness_level === "Tree WTF" || brief.why_this_is_here;

// Newsletter signup
const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
let nlSuccess = false;
let nlError   = "";

if (Astro.request.method === "POST") {
  const form  = await Astro.request.formData();
  const email = form.get("email")?.toString().trim() ?? "";
  if (!email || !EMAIL_RE.test(email)) {
    nlError = "Please enter a valid email address.";
  } else {
    try {
      await sql`
        INSERT INTO newsletter_signups (email, source_page)
        VALUES (${email}, ${`/briefs/${slug}`})
        ON CONFLICT (email) DO NOTHING
      `;
      nlSuccess = true;
    } catch {
      nlError = "Something went wrong. Please try again.";
    }
  }
}

function fmtDate(d: Date | string | null) {
  if (!d) return null;
  return new Date(d).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
}

const publishedDisplay  = fmtDate(brief.published_at);
const sourceDateDisplay = fmtDate(brief.source_published_at);
---

<SiteLayout
  title={brief.title}
  description={brief.summary ?? undefined}
  canonicalPath={`/briefs/${slug}`}
>
  <main class="site-main">
    <div class="brief-detail">

      <!-- Header -->
      <header class="brief-header">
        <div style="display:flex; align-items:center; gap:.5rem; flex-wrap:wrap; margin-bottom:.85rem;">
          <a href={`/categories/${brief.category_slug}`} class="tag">{brief.category_label}</a>
          {brief.impact_badge && <span class="impact-badge">{brief.impact_badge}</span>}
        </div>
        <h1>{brief.title}</h1>
        <div class="brief-meta">
          {brief.source_name && <span>Source: <strong>{brief.source_name}</strong></span>}
          {sourceDateDisplay && <span>Published: {sourceDateDisplay}</span>}
          {publishedDisplay && <span>Added: {publishedDisplay}</span>}
          {brief.urgency === "High" && <span class="urgency-badge">Urgent</span>}
        </div>
        {brief.operator_type_fit && (
          <p class="operator-fit-note">{brief.operator_type_fit}</p>
        )}
      </header>

      <!-- Summary -->
      {brief.summary && (
        <div class="brief-section">
          <div class="brief-section-label">Summary</div>
          <p style="font-size:1rem; line-height:1.7; color:var(--text)">{brief.summary}</p>
        </div>
      )}

      <!-- TSN Take -->
      {brief.tsn_take && (
        <div class="brief-section">
          <div class="brief-section-label">TSN Take</div>
          <div class="tsn-take-block">{brief.tsn_take}</div>
        </div>
      )}

      <!-- Why It Matters -->
      {brief.why_it_matters && (
        <div class="brief-section">
          <div class="brief-section-label">Why It Matters</div>
          <div class="why-block">{brief.why_it_matters}</div>
        </div>
      )}

      <!-- Read Source -->
      <div class="read-source-block">
        <p>
          {brief.source_name
            ? <span>Read the full story at <strong>{brief.source_name}</strong></span>
            : <span>Read the original source</span>}
        </p>
        <a href={brief.source_url} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
          Read Source ↗
        </a>
      </div>

      <!-- Operator Question -->
      {brief.dwell_prompt && (
        <div class="article-module dwell-module">
          <div class="article-module-label">Operator Question</div>
          <p>{brief.dwell_prompt}</p>
        </div>
      )}

      <!-- Related Angle -->
      {relatedAngle && (
        <div class="article-module related-angle-module">
          <div class="article-module-label">Related Angle</div>
          <p>{relatedAngle}</p>
        </div>
      )}

      <!-- Why This Is On TSN -->
      {showWtfModule && (
        <div class="article-module wtf-module">
          <div class="article-module-label">Why This Is On TSN</div>
          <p>{brief.why_this_is_here ?? "Not every tree story is a business lesson. Some are here because tree work touches public safety, property damage, weather, infrastructure, and the occasional deeply weird headline."}</p>
        </div>
      )}

      <!-- Tree Web Design CTA -->
      <div class="twd-cta">
        <strong>Need a faster, better website for your tree service company?</strong>
        <br />
        <a href="https://treewebdesign.com" target="_blank" rel="noopener">Tree Web Design</a> builds websites designed to turn local searches into phone calls.
      </div>

      <!-- Read Next -->
      {related.length > 0 && (
        <section style="margin-bottom:2.5rem">
          <div class="section-head">
            <h2>Read Next</h2>
            <a href={`/categories/${brief.category_slug}`}>More {brief.category_name} →</a>
          </div>
          <div class="related-grid">
            {related.map((r: any) => (
              <a href={`/briefs/${r.slug}`} class="related-card">
                <div style="display:flex; align-items:center; gap:.4rem; flex-wrap:wrap; margin-bottom:.4rem;">
                  <span class="tag">{r.category_label}</span>
                  {r.impact_badge && <span class="impact-badge impact-badge-sm">{r.impact_badge}</span>}
                </div>
                <h4>{r.title}</h4>
                {r.reader_hook && <p class="related-card-hook">{r.reader_hook}</p>}
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Newsletter -->
      <div class="newsletter" id="newsletter">
        <h2>Get the weekly tree service briefing.</h2>
        <p>A short roundup of useful news, gear updates, safety notes, and business ideas — free, for tree service companies.</p>

        {nlSuccess ? (
          <p class="newsletter-success">You're in. Look for the first issue in your inbox.</p>
        ) : (
          <form method="post" class="newsletter-form">
            <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
            <button type="submit" class="btn btn-primary">Subscribe</button>
          </form>
        )}
        {nlError && <p class="newsletter-error">{nlError}</p>}
        <p class="newsletter-note">No spam. Unsubscribe any time.</p>
      </div>

    </div>
  </main>
</SiteLayout>
