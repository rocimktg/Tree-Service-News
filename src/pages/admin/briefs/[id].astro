---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { sql } from "../../../lib/db.mjs";

const { id } = Astro.params;
const briefId = parseInt(id ?? "0");

const categories = await sql`SELECT id, name, label FROM categories ORDER BY name ASC`;
let [brief] = await sql`SELECT * FROM links WHERE id = ${briefId}`;
if (!brief) return Astro.redirect("/admin/briefs");

let error   = "";
let success = Astro.url.searchParams.get("created") === "1"
  ? "Brief created."
  : "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const submitAction = form.get("submit_action")?.toString();

  if (submitAction === "delete") {
    await sql`DELETE FROM links WHERE id = ${briefId}`;
    return Astro.redirect("/admin/briefs");
  }

  const title               = form.get("title")?.toString().trim()               ?? "";
  const source_url          = form.get("source_url")?.toString().trim()          ?? "";
  const source_name         = form.get("source_name")?.toString().trim()         || null;
  const source_published_at = form.get("source_published_at")?.toString().trim() || null;
  const category_id         = parseInt(form.get("category_id")?.toString()       ?? "0");
  const summary             = form.get("summary")?.toString().trim()             || null;
  const tsn_take            = form.get("tsn_take")?.toString().trim()            || null;
  const why_it_matters      = form.get("why_it_matters")?.toString().trim()      || null;
  const is_featured         = form.get("is_featured") === "on";

  let status = brief.status;
  if (submitAction === "publish")   status = "published";
  if (submitAction === "draft")     status = "draft";
  if (submitAction === "archive")   status = "archived";
  if (submitAction === "save")      status = brief.status; // keep current

  if (!title)      error = "Title is required.";
  else if (!source_url)  error = "Source URL is required.";
  else if (!category_id) error = "Category is required.";

  if (!error) {
    const published_at =
      status === "published" && brief.status !== "published"
        ? new Date().toISOString()
        : brief.published_at;

    try {
      const [updated] = await sql`
        UPDATE links SET
          title               = ${title},
          source_url          = ${source_url},
          source_name         = ${source_name},
          source_published_at = ${source_published_at},
          summary             = ${summary},
          tsn_take            = ${tsn_take},
          why_it_matters      = ${why_it_matters},
          category_id         = ${category_id},
          status              = ${status},
          is_featured         = ${is_featured},
          published_at        = ${published_at},
          updated_at          = NOW()
        WHERE id = ${briefId}
        RETURNING *
      `;
      brief = updated;
      success = "Saved.";
    } catch (e) {
      console.error("update-brief:", e);
      error = "Database error. Check the server logs.";
    }
  }
}

// Format source_published_at for the date input (needs YYYY-MM-DD)
const sourceDateValue = brief.source_published_at
  ? new Date(brief.source_published_at).toISOString().split("T")[0]
  : "";

const createdAt  = new Date(brief.created_at).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" });
const publishedAt = brief.published_at
  ? new Date(brief.published_at).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" })
  : null;
---

<AdminLayout title={`Edit: ${brief.title}`}>
  <a href="/admin/briefs" class="back-link">← All Briefs</a>

  <div class="page-header">
    <h1>Edit Brief</h1>
    <span class={`badge badge-${brief.status}`}>{brief.status}</span>
  </div>

  <div class="meta-row">
    <span>ID: <strong>{brief.id}</strong></span>
    <span>Slug: <span class="slug-display">{brief.slug}</span></span>
    <span>Created: <strong>{createdAt}</strong></span>
    {publishedAt && <span>Published: <strong>{publishedAt}</strong></span>}
    {brief.is_featured && <span class="star">★ Featured</span>}
  </div>

  {error   && <div class="alert alert-error">{error}</div>}
  {success && <div class="alert alert-success">{success}</div>}

  <form method="post" class="card">

    <p class="section-label">Source</p>
    <div class="field-row">
      <div class="field">
        <label for="source_url">Source URL <span class="req">*</span></label>
        <input type="url" id="source_url" name="source_url" value={brief.source_url} required />
      </div>
      <div class="field">
        <label for="source_name">Source Name</label>
        <input type="text" id="source_name" name="source_name" value={brief.source_name ?? ""} />
      </div>
    </div>
    <div class="field" style="max-width:220px">
      <label for="source_published_at">Source Published Date</label>
      <input type="date" id="source_published_at" name="source_published_at" value={sourceDateValue} />
    </div>

    <p class="section-label">Content</p>
    <div class="field">
      <label for="title">Title <span class="req">*</span></label>
      <input type="text" id="title" name="title" value={brief.title} required />
    </div>
    <div class="field" style="max-width:280px">
      <label for="category_id">Category <span class="req">*</span></label>
      <select id="category_id" name="category_id" required>
        {categories.map((c) => (
          <option value={c.id} selected={c.id === brief.category_id}>[{c.label}] {c.name}</option>
        ))}
      </select>
    </div>
    <div class="field">
      <label for="summary">Summary</label>
      <textarea id="summary" name="summary">{brief.summary ?? ""}</textarea>
    </div>
    <div class="field">
      <label for="tsn_take">TSN Take</label>
      <textarea id="tsn_take" name="tsn_take">{brief.tsn_take ?? ""}</textarea>
    </div>
    <div class="field">
      <label for="why_it_matters">Why It Matters</label>
      <textarea id="why_it_matters" name="why_it_matters">{brief.why_it_matters ?? ""}</textarea>
    </div>

    <p class="section-label">Settings</p>
    <div class="checkbox-row">
      <input type="checkbox" id="is_featured" name="is_featured" checked={brief.is_featured} />
      <label for="is_featured">Feature this brief (shows as Top Story)</label>
    </div>

    <div class="form-actions">
      <button type="submit" name="submit_action" value="save" class="btn btn-ghost">Save</button>
      {brief.status !== "published" && (
        <button type="submit" name="submit_action" value="publish" class="btn btn-green">Publish</button>
      )}
      {brief.status === "published" && (
        <button type="submit" name="submit_action" value="draft" class="btn btn-gray">Unpublish to Draft</button>
      )}
      {brief.status !== "archived" && (
        <button type="submit" name="submit_action" value="archive" class="btn btn-ghost">Archive</button>
      )}
      <span class="spacer"></span>
      <button
        type="submit"
        name="submit_action"
        value="delete"
        class="btn btn-danger"
        onclick="return confirm('Delete this brief? This cannot be undone.')"
      >
        Delete
      </button>
    </div>

  </form>
</AdminLayout>
