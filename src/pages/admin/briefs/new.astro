---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { sql } from "../../../lib/db.mjs";
import { slugify } from "../../../lib/slugify.mjs";

const categories = await sql`SELECT id, name, label FROM categories ORDER BY name ASC`;

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();

  const title               = form.get("title")?.toString().trim()               ?? "";
  const source_url          = form.get("source_url")?.toString().trim()          ?? "";
  const source_name         = form.get("source_name")?.toString().trim()         || null;
  const source_published_at = form.get("source_published_at")?.toString().trim() || null;
  const category_id         = parseInt(form.get("category_id")?.toString()       ?? "0");
  const summary             = form.get("summary")?.toString().trim()             || null;
  const tsn_take            = form.get("tsn_take")?.toString().trim()            || null;
  const why_it_matters      = form.get("why_it_matters")?.toString().trim()      || null;
  const is_featured         = form.get("is_featured") === "on";
  const status              = form.get("submit_action") === "publish" ? "published" : "draft";

  if (!title)       error = "Title is required.";
  else if (!source_url)   error = "Source URL is required.";
  else if (!category_id)  error = "Category is required.";

  if (!error) {
    // Build a unique slug
    const base = slugify(title);
    let slug = base;
    let n = 0;
    while (true) {
      const [exists] = await sql`SELECT id FROM links WHERE slug = ${slug}`;
      if (!exists) break;
      slug = `${base}-${++n}`;
    }

    const published_at = status === "published" ? new Date().toISOString() : null;

    try {
      const [brief] = await sql`
        INSERT INTO links
          (title, slug, source_url, source_name, source_published_at,
           summary, tsn_take, why_it_matters, category_id, status, is_featured, published_at)
        VALUES
          (${title}, ${slug}, ${source_url}, ${source_name}, ${source_published_at},
           ${summary}, ${tsn_take}, ${why_it_matters}, ${category_id}, ${status}, ${is_featured}, ${published_at})
        RETURNING id
      `;
      return Astro.redirect(`/admin/briefs/${brief.id}?created=1`);
    } catch (e) {
      console.error("create-brief:", e);
      error = "Database error. Check the server logs.";
    }
  }
}
---

<AdminLayout title="New Brief">
  <a href="/admin/briefs" class="back-link">← All Briefs</a>
  <div class="page-header">
    <h1>New Brief</h1>
  </div>

  {error && <div class="alert alert-error">{error}</div>}

  <form method="post" class="card">

    <p class="section-label">Source</p>
    <div class="field-row">
      <div class="field">
        <label for="source_url">Source URL <span class="req">*</span></label>
        <input type="url" id="source_url" name="source_url" placeholder="https://..." required />
      </div>
      <div class="field">
        <label for="source_name">Source Name</label>
        <input type="text" id="source_name" name="source_name" placeholder="e.g. Bandit, TCIA, Arborist Now" />
      </div>
    </div>
    <div class="field" style="max-width:220px">
      <label for="source_published_at">Source Published Date</label>
      <input type="date" id="source_published_at" name="source_published_at" />
    </div>

    <p class="section-label">Content</p>
    <div class="field">
      <label for="title">Title <span class="req">*</span></label>
      <input type="text" id="title" name="title" placeholder="Rewrite the headline for tree service owners" required />
    </div>
    <div class="field" style="max-width:280px">
      <label for="category_id">Category <span class="req">*</span></label>
      <select id="category_id" name="category_id" required>
        <option value="">— Select —</option>
        {categories.map((c) => (
          <option value={c.id}>[{c.label}] {c.name}</option>
        ))}
      </select>
    </div>
    <div class="field">
      <label for="summary">Summary</label>
      <textarea id="summary" name="summary" placeholder="2–4 sentences summarizing what happened. Keep it factual and clear."></textarea>
    </div>
    <div class="field">
      <label for="tsn_take">TSN Take</label>
      <textarea id="tsn_take" name="tsn_take" placeholder="1 short paragraph on the practical angle for tree crews."></textarea>
    </div>
    <div class="field">
      <label for="why_it_matters">Why It Matters</label>
      <textarea id="why_it_matters" name="why_it_matters" placeholder="What should owners, climbers, or crews take from this?"></textarea>
    </div>

    <p class="section-label">Settings</p>
    <div class="checkbox-row">
      <input type="checkbox" id="is_featured" name="is_featured" />
      <label for="is_featured">Feature this brief (shows as Top Story)</label>
    </div>

    <div class="form-actions">
      <button type="submit" name="submit_action" value="draft" class="btn btn-ghost">Save as Draft</button>
      <button type="submit" name="submit_action" value="publish" class="btn btn-green">Publish</button>
    </div>

  </form>
</AdminLayout>
