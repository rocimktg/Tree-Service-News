---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Terms of Service"
  description="Terms of Service for Tree Service News, including rules for use, content disclaimers, third-party platform terms, and liability limitations."
  canonicalPath="/terms-of-service"
>
  <main class="site-main">
    <div style="max-width:760px">
      <h1 style="font-family:var(--serif); font-size:2.25rem; font-weight:700; color:var(--black); margin-bottom:.5rem">
        Terms of Service
      </h1>
      <p style="color:var(--muted); font-size:.9rem; margin-bottom:2rem; padding-bottom:1.5rem; border-bottom:2px solid var(--green)">
